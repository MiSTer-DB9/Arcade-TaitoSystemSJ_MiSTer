		<dip bits="24,25" name="Bonus Life" ids="30000,20000,10000,None"/>
		<dip bits="29" name="Year Display" ids="No,Yes"/>
		<dip bits="30" name="Infinite Lives" ids="Yes,No"/>
		<dip bits="31" name="Coin Slots" ids="Aonly,AandB"/>
	</switches>
